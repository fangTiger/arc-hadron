# Arc Testnet 链参数来源：/Users/captain/python/arc-lepton/lib/wagmi.ts、lib/constants.ts 与 .env.local
# chainId：5042002
# explorer：https://testnet.arcscan.app
ARC_RPC_URL=https://rpc.testnet.arc.network

# 部署私钥：测试网专用、绝不入库。请只在本地 .env 中填写真实值。
DEPLOYER_PRIVATE_KEY=

# 可选：SeedV4/SeedV5 买单账户私钥，逗号分隔；留空时使用 deployer 单账户挂买单。
SEED_BIDDER_PRIVATE_KEYS=

# 协议费金库地址：部署 HadronMarket 时传入 treasury。
TREASURY_ADDRESS=

# 已部署合约地址：SeedV4/SeedV5 从这里读取，不重新部署合约。
HADRON_ASSETS=0xe1F5E51D39944dA026c5030F4e1B18A82F681b42
HADRON_MARKET=0xa836C7EE67803D0227Df25e41F410a363BF13353
HADRON_YIELD=

# 价格口径：Arc testnet 原生 USDC 使用 18 位小数 wei 计价，1 USDC = 1e18。
